generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url    = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  role           Role
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  profilePic     String?        
  notifications  Notification[]       
  facultyProfile FacultyProfile?
  studentProfile StudentProfile?
  tickets Ticket[]

}

model StudentProfile {
  id          Int    @id @default(autoincrement())
  userId      Int    @unique
  rollNumber  String @unique
  designation String
  department  String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointmentRequests AppointmentRequest[] 
  appointments AppointmentUsers[]
}

model FacultyProfile {
  id          Int    @id @default(autoincrement())
  userId      Int    @unique
  department  String
  designation String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointmentRequests AppointmentRequest[] 
  availabilities FacultyAvailability[]
}

model AppointmentRequest {
  id         Int      @id @default(autoincrement())
  studentId   Int
  facultyId   Int
  start      DateTime
  end        DateTime
  purpose   String
  note      String?
  cancellationNote   String?
  status      Status   @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  capacity    Int
  isGroup     Boolean  @default(false)
  student     StudentProfile     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  faculty     FacultyProfile     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  students   AppointmentUsers[]
}

model AppointmentUsers {
  id            Int      @id @default(autoincrement())
  appointmentId Int
  userId        Int
  appointment    AppointmentRequest @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  student        StudentProfile               @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([appointmentId, userId])
}

model FacultyAvailability {
  id         Int      @id @default(autoincrement())
  start     DateTime
  end        DateTime
  facultyId  Int
  faculty    FacultyProfile  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum Role {
  ADMIN
  FACULTY
  STUDENT
}

model Timetable {
  id           Int    @id @default(autoincrement())
  facultyName  String
  day          String
  time         String
}


model Ticket {
  id          Int      @id @default(autoincrement())
  topic       String   // Matches: "Unable to book appointment" [1]
  description String?   // add this (admin page needs it)

  ticketStatus     TSVAL   @default(OPEN) // Matches: "Open" or "Resolved" [1]
  createdAt   DateTime @default(now())  // Matches the "date" field [1]
  updatedAt   DateTime @updatedAt

  // Foreign key to link the ticket to the specific student/user who raised it
  userId      Int      
  user        User     @relation(fields: [userId], references: [id])
}


enum TSVAL{
  OPEN
  RESOLVED
}

model Notification {
  id        String   @id @default(uuid())
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  link      String?
  user User @relation(fields: [userId], references: [id])
}